# --- AI Services ---
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- Database (Supabase Postgres direct connection) ---
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Admin bootstrap ---
ADMIN_EMAILS=gunter@liquidsmarts.com
